{
    "name": "gpslab/geoip2",
    "license": "MIT",
    "type": "symfony-bundle",
    "homepage": "https://github.com/gpslab/geoip2",
    "description": "A Symfony Bundle for the Maxmind GeoIP2 API",
    "autoload": {
        "psr-4": {
            "GpsLab\\Bundle\\GeoIP2Bundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GpsLab\\Bundle\\GeoIP2Bundle\\Tests\\": "tests/"
        }
    },
    "require": {
        "ext-phar": "*",
        "ext-zlib": "*",
        "php": ">=8.1.0",
        "geoip2/geoip2": "~3.0",
        "symfony/http-kernel": "^6.4|^7.3|^7.4|^8.0",
        "symfony/dependency-injection": "^6.4|^7.3|^7.4|^8.0",
        "symfony/expression-language": "^6.4|^7.3|^7.4|^8.0",
        "symfony/config": "^6.4|^7.3|^7.4|^8.0",
        "symfony/console": "^6.4|^7.3|^7.4|^8.0",
        "symfony/filesystem": "^6.4|^7.3|^7.4|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10|^11",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "rector/rector": "^2.3"
    },
    "suggest": {
        "splitbrain/php-archive": "Greatly reduces memory usage for the geoip2:update command"
    }
}
